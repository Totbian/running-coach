# OpenAI Realtime API (already in use by /api/session)
OPENAI_API_KEY=

# --- Google Calendar (Service Account) ---
# Either paste the full service account JSON inline (one line, escape newlines as \n):
GOOGLE_SERVICE_ACCOUNT_JSON=
# ...or point to a file path on disk (don't commit the file):
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
# Reminder: share your Google Calendar with the service account email
# (looks like name@project.iam.gserviceaccount.com) with "Make changes to events".

# --- Google Maps Directions API ---
GOOGLE_MAPS_API_KEY=
